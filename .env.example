# Django Food Ordering System - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================
# DJANGO CONFIGURATION
# ============================================================
DEBUG=True
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================================
# ALLOWED HOSTS (comma-separated)
# ============================================================
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# For PostgreSQL with SSL (Cloud databases like Neon)
# DB_OPTIONS_SSLMODE=require

# ============================================================
# EMAIL CONFIGURATION (Gmail Example)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_specific_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your_email@gmail.com

# For SendGrid (Alternative)
# EMAIL_BACKEND=sendgrid_backend.SendgridBackend
# SENDGRID_API_KEY=your_sendgrid_api_key

# ============================================================
# GOOGLE RECAPTCHA (Form Protection)
# ============================================================
RECAPTCHA_PUBLIC_KEY=your_recaptcha_public_key
RECAPTCHA_PRIVATE_KEY=your_recaptcha_private_key

# ============================================================
# SECURITY SETTINGS (Production)
# ============================================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=True

# ============================================================
# SESSION & TIMEOUT CONFIGURATION
# ============================================================
SESSION_COOKIE_AGE=1209600
AUTO_LOGOUT_IDLE_TIME=200

# ============================================================
# MEDIA FILES CONFIGURATION
# ============================================================
MEDIA_URL=/media/
MEDIA_ROOT=media

# ============================================================
# STATIC FILES CONFIGURATION
# ============================================================
STATIC_URL=/static/
STATIC_ROOT=staticfiles

# ============================================================
# PAYMENT CONFIGURATION (If using external payment gateway)
# ============================================================
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_key
PAYMENT_MERCHANT_ID=your_merchant_id

# ============================================================
# AWS CONFIGURATION (Optional - for media storage)
# ============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_bucket_name
AWS_S3_REGION_NAME=us-east-1

# ============================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# ============================================================
# CACHE CONFIGURATION (Optional)
# ============================================================
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=unique-snowflake

# ============================================================
# TIMEZONE CONFIGURATION
# ============================================================
TIME_ZONE=UTC
USE_I18N=True
USE_L10N=True
USE_TZ=True

# ============================================================
# LANGUAGE CONFIGURATION (Optional)
# ============================================================
LANGUAGE_CODE=en-us

# ============================================================
# NOTES
# ============================================================
# 1. Generate a secure SECRET_KEY:
#    python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
#
# 2. For Gmail, use an App Password (not your regular password):
#    https://support.google.com/accounts/answer/185833
#
# 3. Get reCAPTCHA keys from:
#    https://www.google.com/recaptcha/admin
#
# 4. For production, change DEBUG=False
#
# 5. Set ALLOWED_HOSTS to your actual domain
#
# 6. Use a proper database password (not123456)
#
# 7. Keep this file secure and never commit it to version control
